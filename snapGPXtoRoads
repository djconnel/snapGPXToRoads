def snap_to_roads_position(points, api_key, isLoop = False, interpolate = False):
  '''
  Snap GPS points to roads using Google Maps Roads API.
  Processes points in batches of BATCH_SIZE.

  Args:
    points: List of GPX points
    api_key: Google Maps API key
    interpolate: whether to interpolate

  Returns:
    List of snapped points

  This only deals with position. Elevation and other fields need to be
  handled by the caller
  '''

  # if it's a loop, make sure route closes
  if isLoop and not pointsAreClose(points[0], points[-1]):
    points[-1] = copyPoint(points[0])

  snapped_points = []
  original_indices = []
  # batches:
  # 1 - 100: 1
  # 101 - 199: 2
  # 200 - 298: 3
  # etc
  total_batches = (len(points) + BATCH_SIZE - 3) // (BATCH_SIZE - 1)

  stderr.write(f'Snapping {len(points)} points to roads in {total_batches} batches...\n')

  batch_num = 0
  for i in range(0, len(points), BATCH_SIZE - 1):
    batch_num += 1
    batch = points[i:i + BATCH_SIZE]

    stderr.write(f'Processing batch {batch_num}/{total_batches} ({len(batch)} points)\n')

    # Format points as "lat,lng|lat,lng|..."
    path_string = '|'.join([f'{p.latitude},{p.longitude}' for p in batch])

    # Make API request
    params = {
      'path': path_string,
      'interpolate': str(interpolate),  # Interpolate between points
      'key': api_key
    }

    try:
      response = requests.get(ROADS_API_URL, params=params)
      response.raise_for_status()

      data = response.json()
      key = 'snappedPoints'

      if key in data:
        snappedPoints = data[key]
        if batch_num > 1:
          ps = snappedPoints[1:]
        else:
          ps = snappedPoints
        for snappedPoint in ps:
          location = snappedPoint['location']
          snapped_points.append(gpxpy.gpx.GPXTrackPoint(location['latitude'], location['longitude']))
          if 'originalIndex' in snappedPoint:
            originalIndex = snappedPoint['originalIndex'] + i
          else:
            originalIndex = None
          original_indices.append(originalIndex)
        stderr.write(f'  Received {len(snappedPoints)} snapped points\n')
      else:
        stderr.write(f'  Warning: No snapped points returned for batch {batch_num}\n')
        # Fallback to original points
        snapped_points = points.copy()
    except requests.exceptions.RequestException as e:
      stderr.write(f'  Error processing batch {batch_num}: {e}\n')
      stderr.write(f'  Using original points for this batch\n')
      # Fallback to original points
      snapped_points = points.copy()

  stderr.write(f'Total snapped points: {len(snapped_points)}\n')
  return snapped_points, original_indices


def snap_to_roads(points, api_key, isLoop = False, interpolate = False):
  '''
  Snap GPS points to roads using Google Maps Roads API.
  Processes points in batches of BATCH_SIZE.

  Args:
    points: List of (latitude, longitude) tuples
    api_key: Google Maps API key
    interpolate: whether to do interpolation

  Returns:
    List of snapped points

  Google Maps API tags points with the original point if
  they are direct snaps, then interpolates additional points.
  The altitudes of the original points are transferred directly,
  while interpolated points have linearly interpolated altitudes
  '''

  # now snap with interpolation, additionally interplating altitude
  snappedPoints, snappedIndices = snap_to_roads_position(points = points, api_key = api_key, interpolate = interpolate)

  # report on deviation
  sumd2 = 0
  nSum = 0

  # if not interpolate, just copy the elevations
  if not interpolate:
    for i in range(len(points)):
      p = copyPoint(points[i])
      p.longitude = snappedPoints[i].longitude
      p.latitude = snappedPoints[i].latitude
      snappedPoints[i] = p
    return snappedPoints

  # make sure last point has an snapped index
  if snappedIndices[-1] is None:
    snappedIndices[-1] = len(points) - 1

  # present snapped point: i
  i = 0
  j = 0
  # bracketing points: u, v
  u = 0
  v = 0
  while i < len(snappedPoints):
    # if this is an anchor point, copy the altitude
    if snappedIndices[i] is not None:
      u = snappedIndices[i]
      p = copyPoint(points[u])
      sumd2 += pointDistance(points[u], snappedPoints[i]) ** 2
      nSum += 1
      p.latitude = snappedPoints[i].latitude
      p.longitude = snappedPoints[i].longitude
      snappedPoints[i] = p
      j = i + 1
      v = None
      while j < len(snappedPoints):
        if snappedIndices[j] is None:
          j += 1
        else:
          v = snappedIndices[j]
          break
      i += 1
      continue

    # we are between anchor points: interpolate to next anchor point
    # calculate distances:
    z1 = points[u].elevation
    if v is None:
      z2 = z1
    else:
      z2 = points[v].elevation
    j = i + 1
    while j < len(snappedIndices) - 1 and snappedIndices[j] is None:
      j += 1

    # now u is position of the next anchor point
    ds = [0]
    for k in range(i - 1, j):
      ds.append(ds[-1] + pointDistance(snappedPoints[k], snappedPoints[k + 1]))
    for k in range(i, j):
      f = ds[1 + k - i] / ds[1 + j - i]
      z = z1 * (1 - f) + z2 * f
      snappedPoints[k].elevation = z
    i = j

  if nSum > 0:
    rmsd = sqrt(sumd2 / nSum)
    stderr.write(f'RMS point shift = {rmsd:g} meters\n')

  return snappedPoints

def fixLoopAltitudes(points):
  '''make sure altitudes are smooth at S/F for loop course'''
  p1 = points[-2]
  p2 = points[-1]
  p3 = points[0]
  ds = [0]
  for i in range(1, len(points)):
    ds.append(pointDistance(points[i - 1], points[i]))

  courseDistance = ds[-1] + pointDistance(p2, p3)
  f = (ds[-1] - ds[-2]) / courseDistance
  z = points[-2].elevation * (1 - f) + points[0].elevation * f
  dz = z - points[-1].elevation
  for i in range(len(points)):
    f = ds[i] / courseDistance
    points[i].elevation += dz * f

def deltaPosition(d1, d2, courseDistance=None, isLoop=False):
  delta = d2 - d1
  if isLoop and courseDistance is not None and courseDistance > 0:
    delta -= courseDistance * floor(0.5 + delta / courseDistance)
  return delta

def smoothPoints(points, smoothXY=0, smoothZ=0, isLoop=False):
  '''smooth points with the given sigma values.  Loop courses wrap around.'''
  stderr.write(f'smoothing with xy sigma = {smoothXY}, z sigmaZ = {smoothZ}, isLoop = {isLoop}\n')

  if smoothXY is None or smoothXY < 0:
    smoothXY = 0
  if smoothZ is None or smoothZ < 0:
    smoothZ = 0
  if smoothXY <= 0 and smoothZ <= 0:
    return

  wList = [1]
  for u in range(1, 41):
    wList.append(exp(- u ** 2 / 200))

  N = len(points)
  # create distance field
  ds = [0]
  for i in range(N - 1):
    ds.append(ds[-1] + pointDistance(points[i], points[i + 1]))
  courseDistance = ds[-1]
  if isLoop:
    courseDistance += pointDistance(points[-1], points[0])


  #
  # refine the mesh: add mesh points proximate to points
  #

  # do refinements in order of refinement
  sigmas = []
  if smoothXY > 0:
    sigmas.append(smoothXY)
  if smoothZ > 0:
    sigmas.append(smoothZ)
  if len(sigmas) > 1:
    if sigmas[0] < sigmas[1]:
      s = sigmas[0]
      sigmas[0] = sigmas[1]
      sigmas[1] = s
    # if the sigmas are similar, just use the broader sigma
    if sigmas[0] < 1.2 * sigmas[1]:
      sigmas = [sigmas[0]]

  newPoints = [[[], []] for p in points]
  newDs = [[[], []] for p in points]

  # create refinement region in the zones around each point
  regions = []    # list: for each sigma, for each point, 2 refinement region, each with 2 bounds
  ns = 0
  for sigma in sigmas:
    regions.append([])
    r = 2 * sigma
    for i in range(N):
      d = ds[i]
      d1 = d - r
      if not isLoop and d1 < 0:
        d1 = 0
      if isLoop or i > 0:
       dMid = max(0, interpolatePosition(ds[i - 1], ds[i], 0.5, courseDistance, isLoop))   # midpoint between points
       if d1 < dMid:
         d1 = dMid
      d2 = d + r
      if not isLoop and d1 > courseDistance:
        d1 = courseDistance
      if isLoop or i < N - 1:
       dMid = interpolatePosition(ds[i], ds[(i + 1) % N], 0.5, courseDistance, isLoop)   # midpoint between points
       if d2 > dMid:
         d2 = dMid
      # refinement region for this spacing is from d1 to d2, retaining original point
      regions[ns].append([[d1, d], [d, d2]])

      # if there's an additional region, it gets split
      for n in range(ns):
        regions[n][i][0][1] = d1   # end of first region
        regions[n][i][1][0] = d2   # start of 2nd region
    ns += 1

  nNewPoints = 0
  for i in range(N):
    # sigma regions prior to point
    for ns in range(len(sigmas)):
      spacing = sigmas[ns] / 2
      d1 = regions[ns][i][0][0]
      d2 = regions[ns][i][0][1]
      NPoints = 1 + int((d2 - d1) / spacing)

      # avoid close points at the boundary
      n1 = 0
      dMid = max(0, interpolatePosition(ds[i], ds[i - 1], 0.5, courseDistance, isLoop))   # midpoint between points
      if abs(d1 - dMid) < spacing / 4:
        n1 = 1

      dd = deltaPosition(ds[i - 1], ds[i], courseDistance = courseDistance, isLoop = isLoop)
      for n in range(n1, NPoints):
        d = interpolatePosition(d1, d2, f= n / NPoints, courseDistance = courseDistance)
        f = deltaPosition(ds[i - 1], d, courseDistance = courseDistance, isLoop = isLoop) / dd
        newPoints[i][0].append(interpolatePoint(points[i - 1], points[i], f))
        newDs[i][0].append(d)
        nNewPoints += 1

    # sigma regions after point
    for ns in reversed(range(len(sigmas))):
      spacing = sigmas[ns] / 2
      d1 = regions[ns][i][1][0]
      d2 = regions[ns][i][1][1]
      NPoints = 1 + int((d2 - d1) / spacing)
      dd = deltaPosition(ds[i], ds[(i + 1) % N], courseDistance = courseDistance, isLoop = isLoop)
      for n in range(1, NPoints):
        d = interpolatePosition(d1, d2, f= n / NPoints, courseDistance = courseDistance)
        f = deltaPosition(ds[i], d, courseDistance = courseDistance, isLoop = isLoop) / dd
        newPoints[i][1].append(interpolatePoint(points[i], points[(i + 1) % N], f))
        newDs[i][1].append(d)
        nNewPoints += 1

      # revise possible duplicate points at the boundary
      if isLoop or i < N - 1:
        dMid = interpolatePosition(ds[i], ds[(i + 1) % N] , 0.5, courseDistance, isLoop)   # midpoint between points
        # if we're close to the mid-point, use that instead
        if len(newPoints[i][1]) > 0 and abs(d2 - dMid) < spacing / 4:
          newPoints[i][1][-1] = interpolatePoint(points[i], points[(i + 1) % N], 0.5)
      # end of point to point, don't put a point too close to the final point
      if not isLoop and i == N - 1 and abs(d2 - courseDistance) < spacing / 4 and len(newPoints[i][1]) > 0:
        newPoints[i][1].pop()
        newDs[i][1].pop()
        nNewPoints -= 1

  # if we added new points, splice them in
  # before the first point goes at the end
  if nNewPoints > 0:
    pRefined = []
    dRefined = []
    for i in range(N):
      if i > 0:
        pRefined += newPoints[i][0]
        dRefined += newDs[i][0]
      pRefined += [points[i]] + newPoints[i][1]
      dRefined += [ds[i]] + newDs[i][1]
    if isLoop:
      pRefined += newPoints[0][0]
      dRefined += newDs[0][0]
    points = pRefined
    ds = dRefined
    N = len(points)

  #
  # do smoothing on refined mesh
  #

  newLats = []
  newLons = []
  newEles = []
  if smoothXY > 0:
    uXYs = [d / smoothXY for d in ds]
    cdXY = courseDistance / smoothXY
    j = 0
    k = 0
    if isLoop:
      while ((j - 1) % N != i % N) and deltaPosition(uXYs[j], uXYs[i], cdXY, isLoop) < 3:
        j = (j - 1) % N

    lons = [points[0].longitude]   # avoid antimeridian problems
    for i in range(N - 1):
      dLon = points[i + 1].longitude - points[i].longitude
      dLon -= 360 * floor(0.5 + dLon / 360)
      lons.append(lons[-1] + dLon)

    for i in range(N):
      if isLoop:
        iLast = (i - 1) % N
      else:
        iLast = N - 1
      while (k % N != iLast) and deltaPosition(uXYs[i], uXYs[k], cdXY, isLoop) < 3:
        k = (k + 1) % N
      while (j % N != i) and deltaPosition(uXYs[(j + 1) % N], uXYs[i], cdXY, isLoop) > 3:
        j = (j + 1) % N
      # smooth from k to j
      u = j
      sumw = 0
      sumLat = 0
      sumLon = 0
      while True:
        d = deltaPosition(uXYs[u], uXYs[i], cdXY, isLoop)
        nw = int(10 * abs(d) + 0.5)
        w = wList[int(10 * abs(d) + 0.5)] if nw < len(wList) else 0
        sumw += w
        sumLat += w * points[u].latitude
        sumLon += w * lons[u]
        if u == k:
          break
        u = (u + 1) % N

      lat = sumLat / sumw
      lon = sumLon / sumw
      lon -= 360 * floor(0.5 + lon / 360)
      newLats.append(lat)
      newLons.append(lon)

  if (smoothZ > 0):
    uZs = [d / smoothZ for d in ds]
    cdZ = courseDistance / smoothZ
    j = 0
    k = 0
    if isLoop:
      while ((j - 1) % N != i % N) and deltaPosition(uZs[j], uZs[i], cdZ, isLoop) < 3:
        j = (j - 1) % N

    lons = [points[0].longitude]   # avoid antimeridian problems
    for i in range(N - 1):
      dLon = points[i + 1].longitude - points[i].longitude
      dLon -= 360 * floor(0.5 + dLon / 360)
      lons.append(lons[-1] + dLon)

    for i in range(N):
      if isLoop:
        iLast = (i - 1) % N
      else:
        iLast = N - 1
      while (k % N != iLast) and deltaPosition(uZs[i], uZs[k], cdZ, isLoop) < 3:
        k = (k + 1) % N
      while (j % N != i) and deltaPosition(uZs[(j + 1) % N], uZs[i], cdZ, isLoop) > 3:
        j = (j + 1) % N
      # smooth from k to j
      u = j
      sumw = 0
      sumEle = 0
      while True:
        d = deltaPosition(uZs[u], uZs[i], cdZ, isLoop)
        nw = int(10 * abs(d) + 0.5)
        w = wList[int(10 * abs(d) + 0.5)] if nw < len(wList) else 0
        sumw += w
        sumEle += w * points[u].elevation
        if u == k:
          break
        u = (u + 1) % N

      ele = sumEle / sumw
      newEles.append(ele)

  if len(newLons) > 0:
    for p, lat, lon  in zip(points, newLats, newLons):
      p.latitude = lat
      p.longitude = lon

  if len(newEles) > 0:
    for p, ele  in zip(points, newEles):
      p.elevation = ele

  return points

def export_gpx(points, output_file, input_file):
  '''
  Export snappped points to a new GPX file.

  Args:
    points: List GPX points
    output_file: filepointer to output file
    input_file: filepointer to input file
  '''
    # Create new GPX object
  gpx = gpxpy.gpx.GPX()

  # Copy metadata from original if available
  if input_file:
    try:
      original_gpx = gpxpy.parse(input_file)
      if original_gpx.name:
        gpx.name = f'{original_gpx.name} (Snapped)'
      if original_gpx.description:
        gpx.description = original_gpx.description
    except:
      pass

  # Create a track and segment
  gpx_track = gpxpy.gpx.GPXTrack()
  gpx.tracks.append(gpx_track)
  gpx_track.name = 'Snapped Track'

  gpx_segment = gpxpy.gpx.GPXTrackSegment()
  gpx_track.segments.append(gpx_segment)

  # Add all snapped points
  gpx_segment.points = points

  # Write to file
  output_file.write(gpx.to_xml())

  stderr.write(f'Successfully exported {len(points)} points\n')


def main():
  '''Main function to orchestrate the GPX snapping process.'''

  parser = argparse.ArgumentParser(
    formatter_class = argparse.RawTextHelpFormatter,
    description= __doc__
  )

  parser.add_argument(
    '-i', '--input', '--in',
    type=str,
    default=None,
    help='Name of input file, or use -i- for standard input (default).'
  )

  parser.add_argument(
    '-o', '--output', '--out',
    type=str,
    default=None,
    help='Name of output file, or use -o- for standard output (default).'
  )

  parser.add_argument(
    '-a', '--apikey', '--APIKey',
    type=str,
    default= API_KEY,
    help='39 character Google Maps API key.'
  )

  parser.add_argument(
    '--snap',
    action=argparse.BooleanOptionalAction,
    default=True,
    help='Specify snapping should be done, which is the default',
  )

  parser.add_argument(
    '-I', '--interpolate',
    action=argparse.BooleanOptionalAction,
    default=True,
    help='Enable or disable interpolation (optional, default: True).',
  )

  parser.add_argument(
    '-s', '--simplify',
    action=argparse.BooleanOptionalAction,
    default=True,
    help='whether the simplificatin algorithm is used before snapping to reduce the number of API calls',
  )

  parser.add_argument(
    '-l', '--loop',
    default=None,
    help='specify that the course is m loop.  This is normally determined automatically.  Specify no loop with --no-loop.',
  )

  parser.add_argument(
    '--smoothXY', '--sigmaXY', '--smoothxy', '--sigmaxy',
    type=float,
    default=None,
    help='smoothing distance applied to positions (default = 0)',
  )

  parser.add_argument(
    '--smoothZ', '--sigmaZ', '--smoothz', '--sigmaz',
    type=float,
    default=None,
    help='smoothing distance applied to elevations (default = 0)',
  )

  parser.add_argument(
    '--smoothing', '--sigma',
    type=float,
    default=0,
    help='smoothing distance applied to both elevations and positions elevations (default = 0)',
  )

  parser.add_argument(
    '--smooth',
    action=argparse.BooleanOptionalAction,
    default=False,
    help='specifies default smoothing',
  )

  args = parser.parse_args()

  # --- Access the parsed values ---
  input_file = args.input
  output_file = args.output
  snap = args.snap
  interpolate = args.interpolate
  simplify = args.simplify
  isLoop = args.loop
  api_key = args.apikey
  if args.smooth:
    smoothXY = args.smooth
    smoothZ  = 12
  if smoothXY is None:
    if args.smoothXY is None:
      smoothXY = 0
    else:
      smoothXY = args.smoothZ
  if smoothZ is None:
    if args.smoothZ is None:
      smoothZ = 0
    else:
      smoothZ = args.smoothZ
  smoothXY = sqrt(smoothXY ** 2 + args.smoothing ** 2)
  smoothZ  = sqrt(smoothZ ** 2 + args.smoothing ** 2)
  stderr.write(f'input_file = {input_file}\noutput_file = {output_file}\ninterpolate = {interpolate}\napi_key = {api_key}, isLoop = {isLoop}\n')

  if isinstance(input_file, str):
    if input_file == '-':
      input_file = stdin
    else:
      try:
        stderr.write(f'opening input file : {input_file}\n')
        input_file = open(input_file, 'r')
      except:
        stderr.write('Error opening file ' + input_file + '\n')
  else:
    input_file = stdin
  if isinstance(output_file, str):
    if output_file == '-':
      output_file = stdout
    else:
      try:
        stderr.write(f'opening output file : {output_file}\n')
        output_file = open(output_file, 'w')
      except:
        stderr.write('Error opening file ' + output_file + '\n')
        sys.exit(1)
  else:
    output_file = stdout


  if api_key is None or not re.fullmatch(API_KEY_RE, api_key):
    stderr.write('Error: Please provide a valid Google Maps API key\n')
    stderr.write('Either edit the API_KEY variable in the script or pass it as a command line argument\n')
    sys.exit(1)

  try:
    # Step 1: Load GPX file
    points = removeDuplicatePoints(load_gpx(input_file))

    if not points:
      stderr.write('Error: No points found in GPX file\n')
      sys.exit(1)

    if isLoop is None:
      isLoop = checkLoop(points = points)
      stderr.write(f'auto-setting isLoop = {isLoop}\n')

    if isLoop:
      stderr.write('The route is a circuit\n')
      if not pointsAreClose(points[0], points[-1]):
        points.append(copyPoint(points[-1]))
      else:
        stderr.write('The route is not a circuit\n')

    stderr.write(f'initial points = {len(points)}\n')

    # Step 2: simplify points
    if simplify:
      points = simplifyPoints(points= points)
      stderr.write(f'simplified points = {len(points)}\n')

    if snap:
      # Step 3: Snap points to roads
      points = snap_to_roads(points = points, api_key = api_key, interpolate= interpolate, isLoop= isLoop)

    # step 4: make sure altitudes are smooth (if it's a loop course)
    if isLoop:
      fixLoopAltitudes(points = snapped_points)

    # step 5: smooth points
    points = smoothPoints(points= points, smoothXY= smoothXY, smoothZ= smoothZ, isLoop= isLoop)

    # step 6: export points
    export_gpx(points= points, output_file = output_file, input_file = input_file)

    stderr.write('\n✓ Process completed successfully!\n')

  except FileNotFoundError:
    stderr.write(f'Error: Could not find file "{input_file}"\n')
    sys.exit(1)
  except Exception as e:
    stderr.write(f'Error: {e}\n')
    import traceback
    traceback.print_exc()
    sys.exit(1)


if __name__ == '__main__':
  main()

